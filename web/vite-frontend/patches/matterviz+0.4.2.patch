+      if (!drag_start || !viewport_element || !camera || !structure?.sites) return
+      const rect = viewport_element.getBoundingClientRect()
+      const left = Math.min(drag_start.x, x) - rect.left
+      const right = Math.max(drag_start.x, x) - rect.left
+      const top = Math.min(drag_start.y, y) - rect.top
